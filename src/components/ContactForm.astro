---
import { FORMSPREE_ENDPOINT } from '../lib/constants';
---

<section id="contact" class="py-16 px-4">
  <div class="max-w-2xl mx-auto">
    <h2 class="text-2xl sm:text-3xl font-heading font-bold text-center mb-8" style="color: var(--color-text)">
      Contact Me
    </h2>
    <form action={FORMSPREE_ENDPOINT} method="POST" class="space-y-6">
      <div>
        <label for="name" class="block text-sm font-medium mb-1" style="color: var(--color-text)">Name</label>
        <input
          type="text"
          name="name"
          id="name"
          required
          class="w-full px-4 py-3 rounded-lg border text-sm focus:outline-none focus:ring-2 focus:ring-primary"
          style="background: var(--color-surface); border-color: var(--color-border); color: var(--color-text)"
          placeholder="Your name"
        />
      </div>
      <div>
        <label for="email" class="block text-sm font-medium mb-1" style="color: var(--color-text)">Email</label>
        <input
          type="email"
          name="_replyto"
          id="email"
          required
          class="w-full px-4 py-3 rounded-lg border text-sm focus:outline-none focus:ring-2 focus:ring-primary"
          style="background: var(--color-surface); border-color: var(--color-border); color: var(--color-text)"
          placeholder="your@email.com"
        />
      </div>
      <div>
        <label for="message" class="block text-sm font-medium mb-1" style="color: var(--color-text)">Message</label>
        <textarea
          name="message"
          id="message"
          rows="5"
          required
          class="w-full px-4 py-3 rounded-lg border text-sm focus:outline-none focus:ring-2 focus:ring-primary resize-none"
          style="background: var(--color-surface); border-color: var(--color-border); color: var(--color-text)"
          placeholder="Your message..."
        ></textarea>
      </div>
      <input type="hidden" name="_subject" value="New submission!" />
      <input type="text" name="_gotcha" class="hidden" tabindex="-1" autocomplete="off" />
      <div class="text-center">
        <button type="submit" class="btn-primary">
          Send Message
        </button>
      </div>
    </form>
  </div>
</section>
