---
import { Image } from 'astro:assets';
import { getPortfolioImage } from '../lib/images';

interface Props {
  title: string;
  img: string;
  alt: string;
  category: string;
  slug: string;
}

const { title, img, alt, category, slug } = Astro.props;
const portfolioImg = getPortfolioImage(img);
---

<a href={`/projects/${slug}`} class="group block rounded-lg overflow-hidden transition-transform hover:scale-[1.02]" style="background: var(--color-surface)">
  <div class="relative aspect-[900/650] overflow-hidden">
    <Image
      src={portfolioImg}
      alt={alt}
      width={900}
      height={650}
      loading="lazy"
      class="w-full h-full object-cover transition-transform group-hover:scale-105"
    />
    <div class="absolute inset-0 bg-black/0 group-hover:bg-black/40 transition-colors flex items-center justify-center">
      <span class="text-white font-heading font-bold text-lg opacity-0 group-hover:opacity-100 transition-opacity">
        {title}
      </span>
    </div>
  </div>
  <div class="p-4">
    <h3 class="font-heading font-bold text-sm mb-1" style="color: var(--color-text)">{title}</h3>
    <p class="text-xs" style="color: var(--color-muted)">{category}</p>
  </div>
</a>
