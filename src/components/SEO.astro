---
import { SITE } from '../lib/constants';

interface Props {
  title?: string;
  description?: string;
  type?: 'website' | 'article';
}

const { title, description = SITE.description, type = 'website' } = Astro.props;
const pageTitle = title ? `${title} | ${SITE.title}` : SITE.title;
const canonicalURL = new URL(Astro.url.pathname, SITE.siteUrl);
const imageURL = new URL('/img/profile.webp', SITE.siteUrl);
---

<title>{pageTitle}</title>
<meta name="description" content={description} />
<meta name="author" content={SITE.author} />
<link rel="canonical" href={canonicalURL} />
<meta name="robots" content="index, follow" />
<meta property="og:type" content={type} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={pageTitle} />
<meta property="og:description" content={description} />
<meta property="og:site_name" content={SITE.title} />
<meta property="og:locale" content="en_US" />
<meta property="og:image" content={imageURL} />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={pageTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:site" content={SITE.twitterHandle} />
<meta name="twitter:creator" content={SITE.twitterHandle} />
<meta name="twitter:image" content={imageURL} />
<link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />
<link rel="alternate" type="application/rss+xml" title={`${SITE.title} RSS`} href="/rss.xml" />
