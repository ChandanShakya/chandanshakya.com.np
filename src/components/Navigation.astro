---
import { NAVIGATION } from '../lib/constants';
import ThemeToggle from './ThemeToggle.astro';
---

<nav transition:persist class="fixed top-0 left-0 right-0 z-50" style="background: var(--color-bg); border-bottom: 4px solid var(--color-border);">
  <div class="max-w-6xl mx-auto px-5 sm:px-6">
    <div class="flex items-center justify-between h-16">
      <a href="/" class="pixel-xs sm:pixel-sm font-heading" style="color: var(--color-text); text-decoration: none;">
        CHANDAN
      </a>

      <!-- Desktop nav -->
      <div class="hidden sm:flex items-center gap-6">
        {NAVIGATION.map((item) => (
          <a
            href={item.href}
            data-nav-link={item.href}
            class="text-xl transition-colors min-h-[44px] flex items-center"
            style="color: var(--color-muted); text-decoration: none;"
          >
            {item.label}
          </a>
        ))}
        <ThemeToggle />
      </div>

      <!-- Mobile menu button -->
      <div class="sm:hidden flex items-center gap-4">
        <ThemeToggle />
        <label for="mobile-menu-toggle" class="cursor-pointer p-2 min-h-[44px] flex items-center" aria-label="Toggle menu">
          <span class="pixel-xs font-heading" style="color: var(--color-text);">MENU</span>
        </label>
      </div>
    </div>
  </div>

  <!-- Mobile menu -->
  <input type="checkbox" id="mobile-menu-toggle" class="hidden peer" />
  <div class="sm:hidden hidden peer-checked:block pixel-dialog" style="position: absolute; top: 100%; left: 0; right: 0; z-index: 50;">
    <div class="py-3 space-y-1">
      {NAVIGATION.map((item) => (
        <a
          href={item.href}
          data-nav-link={item.href}
          class="block py-3 text-xl min-h-[48px] flex items-center"
          style="color: var(--color-muted); text-decoration: none;"
        >
          {'>'} {item.label}
        </a>
      ))}
    </div>
  </div>
</nav>
<div class="h-16"></div>

<script is:inline>
  function updateNavActive() {
    var path = window.location.pathname;
    document.querySelectorAll('[data-nav-link]').forEach(function(link) {
      var href = link.getAttribute('data-nav-link');
      var isActive = path === href || (href !== '/' && path.startsWith(href));
      if (isActive) {
        link.style.color = 'var(--color-primary)';
      } else {
        link.style.color = 'var(--color-muted)';
      }
    });
  }
  updateNavActive();
  document.addEventListener('astro:page-load', updateNavActive);
</script>
