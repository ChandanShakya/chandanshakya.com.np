---
import { Image } from 'astro:assets';
import { SITE } from '../lib/constants';
import { getProfileImage } from '../lib/images';
import SocialLinks from './SocialLinks.astro';

const profileImg = getProfileImage();
---

<header class="text-center py-16 sm:py-24 px-4">
  <Image
    src={profileImg}
    alt="Chandan Shakya"
    width={256}
    height={256}
    loading="eager"
    fetchpriority="high"
    class="w-32 h-32 sm:w-40 sm:h-40 rounded-full mx-auto mb-6 object-cover"
  />
  <h1 class="text-3xl sm:text-4xl font-heading font-bold mb-2" style="color: var(--color-text)">
    {SITE.title}
  </h1>
  <p class="text-lg mb-6" style="color: var(--color-muted)">{SITE.skills}</p>
  <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-6">
    <button data-resume-open class="btn-outline cursor-pointer">
      View Resume
    </button>
  </div>
  <SocialLinks />
</header>
