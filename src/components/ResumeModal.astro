---
---

<div id="resume-modal" class="fixed inset-0 z-[100] hidden items-center justify-center p-4" role="dialog" aria-modal="true" aria-label="Resume viewer">
  <div id="resume-backdrop" class="absolute inset-0 bg-black/60"></div>
  <div id="resume-panel" class="relative w-full max-w-3xl h-[85vh] pixel-dialog overflow-hidden flex flex-col" style="background: var(--color-bg);">
    <!-- Header bar -->
    <div class="flex items-center justify-between px-5 py-3 shrink-0" style="border-bottom: 4px solid var(--color-border);">
      <h2 class="font-heading text-[0.5rem]" style="color: var(--color-text);">CHANDAN SHAKYA — RESUME</h2>
      <div class="flex items-center gap-3">
        <a href="/files/ChandanShakyaCV.pdf" download="ChandanShakyaCV.pdf"
           class="pixel-btn text-[0.4rem] py-2 px-4"
           style="text-decoration: none;">
          DOWNLOAD
        </a>
        <button id="resume-close" class="pixel-toggle text-sm" aria-label="Close">✕</button>
      </div>
    </div>
    <!-- PDF viewer -->
    <div id="pdf-container" class="flex-1 min-h-0 overflow-auto" style="background: var(--color-surface);"></div>
  </div>
</div>

<script is:inline type="module">
  import * as pdfjsLib from '/pdf.min.mjs';
  pdfjsLib.GlobalWorkerOptions.workerSrc = '/pdf.worker.min.mjs';

  var pdfDoc = null;

  function initResumeModal() {
    var modal = document.getElementById('resume-modal');
    if (!modal) return;
    var backdrop = document.getElementById('resume-backdrop');
    var panel = document.getElementById('resume-panel');
    var closeBtn = document.getElementById('resume-close');
    var container = document.getElementById('pdf-container');

    function open() {
      modal.classList.remove('hidden');
      modal.classList.add('flex');
      requestAnimationFrame(function() {
        backdrop.style.opacity = '1';
        panel.style.opacity = '1';
        panel.style.transform = 'translateY(0) scale(1)';
      });
      document.body.style.overflow = 'hidden';
      loadPDF(container);
    }

    function close() {
      backdrop.style.opacity = '0';
      panel.style.opacity = '0';
      panel.style.transform = 'translateY(16px) scale(0.97)';
      setTimeout(function() {
        modal.classList.add('hidden');
        modal.classList.remove('flex');
        document.body.style.overflow = '';
      }, 200);
      destroyPDF();
    }

    function destroyPDF() {
      if (pdfDoc) {
        pdfDoc.destroy();
        pdfDoc = null;
      }
      container.innerHTML = '';
    }

    document.querySelectorAll('[data-resume-open]').forEach(function(el) {
      el.addEventListener('click', function(e) { e.preventDefault(); open(); });
    });
    closeBtn.addEventListener('click', close);
    backdrop.addEventListener('click', close);
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && !modal.classList.contains('hidden')) close();
    });
  }

  function loadPDF(container) {
    if (pdfDoc) return;
    container.innerHTML = '<div style="display:flex;align-items:center;justify-content:center;height:100%;color:var(--color-muted);">Loading PDF...</div>';

    var loadingTask = pdfjsLib.getDocument('/files/ChandanShakyaCV.pdf');
    loadingTask.promise.then(function(pdf) {
      pdfDoc = pdf;
      container.innerHTML = '';
      for (var i = 1; i <= pdf.numPages; i++) {
        renderPage(pdf, i, container);
      }
    }).catch(function() {
      container.innerHTML = '<div style="display:flex;align-items:center;justify-content:center;height:100%;color:var(--color-muted);">Failed to load PDF.</div>';
    });
  }

  function renderPage(pdf, pageNum, container) {
    pdf.getPage(pageNum).then(function(page) {
      var viewport = page.getViewport({ scale: 1.5 });
      var canvas = document.createElement('canvas');
      canvas.className = 'pdf-page';
      canvas.width = viewport.width;
      canvas.height = viewport.height;
      page.render({ canvasContext: canvas.getContext('2d'), viewport: viewport });
      container.appendChild(canvas);
    });
  }

  initResumeModal();
  document.addEventListener('astro:page-load', function() { pdfDoc = null; initResumeModal(); });
</script>

<style>
  #resume-backdrop {
    opacity: 0;
    transition: opacity 0.2s ease;
  }
  #resume-panel {
    opacity: 0;
    transform: translateY(16px) scale(0.97);
    transition: opacity 0.2s ease, transform 0.2s ease;
  }
  #pdf-container {
    scrollbar-width: thin;
    scrollbar-color: var(--color-border) var(--color-surface);
  }
  .pdf-page {
    width: 100%;
    height: auto;
    display: block;
    margin-bottom: 8px;
    box-shadow: 4px 0 0 0 var(--color-border), -4px 0 0 0 var(--color-border), 0 4px 0 0 var(--color-border), 0 -4px 0 0 var(--color-border);
  }
</style>
