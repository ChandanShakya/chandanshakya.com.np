---
---

<div id="resume-modal" class="fixed inset-0 z-[100] hidden items-center justify-center p-4" role="dialog" aria-modal="true" aria-label="Resume viewer">
  <div id="resume-backdrop" class="absolute inset-0 bg-black/60 backdrop-blur-sm"></div>
  <div id="resume-panel" class="relative w-full max-w-3xl h-[85vh] rounded-2xl shadow-2xl overflow-hidden flex flex-col" style="background: var(--color-bg)">
    <!-- Header bar -->
    <div class="flex items-center justify-between px-5 py-3 border-b shrink-0" style="border-color: var(--color-border)">
      <h2 class="font-heading font-bold text-sm" style="color: var(--color-text)">Chandan Shakya — Resume</h2>
      <div class="flex items-center gap-3">
        <a href="/files/ChandanShakyaCV.pdf" download="ChandanShakyaCV.pdf"
           class="text-xs font-medium px-3 py-1.5 rounded-lg transition-colors hover:opacity-80"
           style="background: var(--color-primary); color: white;">
          Download
        </a>
        <button id="resume-close" class="p-1.5 rounded-lg transition-colors hover:bg-gray-200 dark:hover:bg-gray-700" aria-label="Close">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--color-text)">
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
        </button>
      </div>
    </div>
    <!-- PDF viewer -->
    <div class="flex-1 min-h-0">
      <iframe src="/files/ChandanShakyaCV.pdf" class="w-full h-full border-0" title="Resume"></iframe>
    </div>
  </div>
</div>

<script is:inline>
(function() {
  var modal = document.getElementById('resume-modal');
  var backdrop = document.getElementById('resume-backdrop');
  var panel = document.getElementById('resume-panel');
  var closeBtn = document.getElementById('resume-close');
  var triggers = document.querySelectorAll('[data-resume-open]');

  function open() {
    modal.classList.remove('hidden');
    modal.classList.add('flex');
    requestAnimationFrame(function() {
      backdrop.style.opacity = '1';
      panel.style.opacity = '1';
      panel.style.transform = 'translateY(0) scale(1)';
    });
    document.body.style.overflow = 'hidden';
  }

  function close() {
    backdrop.style.opacity = '0';
    panel.style.opacity = '0';
    panel.style.transform = 'translateY(16px) scale(0.97)';
    setTimeout(function() {
      modal.classList.add('hidden');
      modal.classList.remove('flex');
      document.body.style.overflow = '';
    }, 200);
  }

  triggers.forEach(function(el) { el.addEventListener('click', function(e) { e.preventDefault(); open(); }); });
  closeBtn.addEventListener('click', close);
  backdrop.addEventListener('click', close);
  document.addEventListener('keydown', function(e) { if (e.key === 'Escape' && !modal.classList.contains('hidden')) close(); });
})();
</script>

<style>
  #resume-backdrop {
    opacity: 0;
    transition: opacity 0.2s ease;
  }
  #resume-panel {
    opacity: 0;
    transform: translateY(16px) scale(0.97);
    transition: opacity 0.2s ease, transform 0.2s ease;
  }
</style>
