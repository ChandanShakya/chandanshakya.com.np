---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 - Not Found">
  <div class="flex flex-col items-center justify-center min-h-[60vh] px-5 text-center">
    <h1 class="pixel-xl sm:pixel-2xl font-heading mb-4" style="color: var(--color-text);">404</h1>
    <p class="text-2xl mb-8" style="color: var(--color-muted);">GAME OVER — PAGE NOT FOUND</p>
    <a href="/" class="pixel-btn min-h-[48px] inline-flex items-center" style="text-decoration: none;">CONTINUE?</a>
  </div>
</BaseLayout>
